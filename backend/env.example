# ===================================================
# ENVIRONMENT VARIABLES TEMPLATE
# ===================================================
# Copy this file to .env and fill in your actual values
# Command: cp env.example .env
# ===================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration (comma-separated, no spaces)
# Production: https://your-domain.com,https://www.your-domain.com
# Development: Include localhost for testing
ALLOWED_ORIGINS=https://dsmuaythaiticket.com,https://www.dsmuaythaiticket.com,http://localhost:3000,http://localhost:5173

# Email Configuration (Gmail SMTP)
# Get App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
ADMIN_EMAIL=admin@example.com

# Pay Solutions API Configuration
# Get credentials from: https://merchant.paysolutions.asia/
PAY_SOLUTIONS_API_URL=https://apis.paysolutions.asia/tep/api/v2/promptpaynew
PAY_SOLUTIONS_MERCHANT_ID=your-8-digit-merchant-id
PAY_SOLUTIONS_AUTH_KEY=your-jwt-auth-token-here
PAY_SOLUTIONS_API_KEY=your-api-key
PAY_SOLUTIONS_SECRET_KEY=your-secret-key

# API Authentication Keys
# Generate strong random keys (use: openssl rand -hex 32)
ADMIN_API_KEY=generate-strong-random-key-minimum-32-chars
INTERNAL_API_KEY=generate-another-strong-random-key-32-chars

